# GoHighLevel CRM integration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# If any of these are missing, /api/quote-submit will return a clear
# "CRM not configured" response and (in development) save the submission
# locally under .local-quotes/.

# Personal Access Token / API key for the GoHighLevel API
GHL_API_KEY=

# Sub-account (location) ID quotes should be created under
GHL_LOCATION_ID=

# Pipeline that new quote opportunities belong to
GHL_PIPELINE_ID=

# Stage within the pipeline that new opportunities start in
GHL_STAGE_ID=

# Base URL for the GoHighLevel API (e.g. https://services.leadconnectorhq.com)
GHL_API_BASE_URL=

# Optional: override Node environment (development | production | test)
# NODE_ENV=development
